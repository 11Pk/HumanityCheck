{
  "manifest_version": 3,
  "name": "Humanity Check",
  "version": "1.0",

  "action": {
    "default_popup": "index.html"
  },

  "content_security_policy": {
  "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'",
  "content_scripts": "script-src 'self' https://cdn.jsdelivr.net https://storage.googleapis.com; object-src 'self'"
},

"web_accessible_resources": [
  {
    "resources": ["mediapipe-wasm/*","face_landmarker.task","src/offscreen/offscreen.html"],
    "matches": ["<all_urls>"]
  }
],

  "permissions": ["activeTab", "scripting","tabs","offscreen"],
    "host_permissions": [
    "https://web.telegram.org/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://meet.google.com/*",
    "https://leetcode.com/*",
    "https://hackerrank.com/*"
  ],

  "content_scripts": [
    {
      

      "matches": ["*://web.telegram.org/*","*://twitter.com/*",
        "*://x.com/*","https://meet.google.com/*", "https://leetcode.com/*", "https://hackerrank.com/*"],
      "js": ["src/scripts/index.js"],
      "type": "module"
    }
  ],

  "background": {
    "service_worker": "src/background/background.js"
  }
}