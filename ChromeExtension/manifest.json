{
  "manifest_version": 3,
  "name": "Humanity Check",
  "version": "1.0",

  "action": {
    "default_popup": "index.html"
  },

  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://web.telegram.org/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://meet.google.com/*",
    "https://leetcode.com/*",
    "https://hackerrank.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://twitter.com/*", "*://x.com/*"],
      "js": ["src/scripts/twitterProfile.js"],
      "type": "module"
    },
    {
      "matches": ["*://web.telegram.org/*"],
      "js": ["src/scripts/chat.js"],
      "type": "module"
    },
    {
      "matches": ["https://meet.google.com/*", "https://leetcode.com/*", "https://hackerrank.com/*"],
      "js": ["src/scripts/index.js"],
      "type": "module"
    }
  ],
  "background": {
    "service_worker": "src/background/background.js"
  }
}